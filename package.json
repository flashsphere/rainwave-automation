{
  "name": "rainwave-automation-extension",
  "description": "Adds automation features, auto voting and requests, to rainwave.cc",
  "private": true,
  "version": "1.3.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "format": "prettier --write src/",
    "lint": "eslint src/ && tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "postinstall": "wxt prepare",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^5.9.2",
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/auto-icons": "^1.1.1",
    "@wxt-dev/module-react": "^1.2.2",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9",
    "wxt": "^0.20.26"
  }
}
